body {
    font-family: Arial;
    text-align: center;
    background-color: #f4f4f4;
}

.panel {
    background: white;
    padding: 20px;
    margin: 50px auto;
    width: 300px;
    border-radius: 10px;
    box-shadow: 0 0 10px gray;
}

button {
    padding: 10px 20px;
    margin: 5px;
    cursor: pointer;
}
